1) Problem Statement: Employee Management System

import java.util.*;
// Employee Class
class Employee {
    protected int id;
    protected String name;
    protected double salary;

    static int totalEmployees = 0; // Static Counter

    public Employee(int id, String name, double salary) {
        this.id = id;
        this.name = name;
        this.salary = salary;
        totalEmployees++;
    }

    public void applyRaise(double percent) {
        salary += salary * percent / 100;
    }

    public int getId() {
        return id;
    }

    public void display() {
        System.out.println("ID: " + id + ", Name: " + name + ", Salary: " + salary);
    }
}

// Manager Class (Inheritance)
class Manager extends Employee {
    private String departmentName;

    public Manager(int id, String name, double salary, String departmentName) {
        super(id, name, salary);
        this.departmentName = departmentName;
    }

    @Override
    public void display() {
        System.out.println("Manager -> ID: " + id + ", Name: " + name +
                ", Salary: " + salary + ", Dept: " + departmentName);
    }
}

// Department Class
class Department {tr
    private Sing deptName;
    private List<Employee> employees;

    public Department(String deptName) {
        this.deptName = deptName;
        employees = new ArrayList<>();
    }

    public String getDeptName() {
        return deptName;
    }

    public void addEmployee(Employee e) {
        employees.add(e);
    }

    public void removeEmployee(int id) {
        Iterator<Employee> it = employees.iterator();
        while (it.hasNext()) {
            Employee e = it.next();
            if (e.getId() == id) {
                it.remove();
                System.out.println("Employee removed successfully!");
                return;
            }
        }
        System.out.println("Employee not found!");
    }

    public void displayEmployees() {
        if (employees.isEmpty()) {
            System.out.println("No employees in this department.");
            return;
        }
        for (Employee e : employees) {
            e.display();
        }
    }

    public void applyRaise(double percent) {
        for (Employee e : employees) {
            e.applyRaise(percent);
        }
    }
}

// CompanyHR Class
class CompanyHR {
    private List<Department> departments;

    public CompanyHR() {
        departments = new ArrayList<>();
    }

    public void addDepartment(String name) {
        departments.add(new Department(name));
        System.out.println("Department added!");
    }

    public Department findDepartment(String name) {
        for (Department d : departments) {
            if (d.getDeptName().equalsIgnoreCase(name)) {
                return d;
            }
        }
        return null;
    }

    public void displayDepartments() {
        if (departments.isEmpty()) {
            System.out.println("No departments available.");
            return;
        }

        for (Department d : departments) {
            System.out.println("\nDepartment: " + d.getDeptName());
            d.displayEmployees();
        }
    }

    public void applyRaiseToAll(double percent) {
        for (Department d : departments) {
            d.applyRaise(percent);
        }
        System.out.println("Salary updated for all employees!");
    }
}

// Tester Class (Main Menu)
public class Tester {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        CompanyHR company = new CompanyHR();
        while (true) {
            System.out.println("\n===== Employee Management System =====");
            System.out.println("1. Add Department");
            System.out.println("2. Add Employee/Manager");
            System.out.println("3. Display Employees in Department");
            System.out.println("4. Remove Employee");
            System.out.println("5. Apply Raise to All Employees");
            System.out.println("6. Display Departments");
            System.out.println("7. Total Employees");
            System.out.println("8. Exit");
            System.out.print("Enter choice: ");
            int choice = sc.nextInt();
            switch (choice) {
                case 1:
                    System.out.print("Enter Department Name: ");
                    sc.nextLine();
                    String deptName = sc.nextLine();
                    company.addDepartment(deptName);
                    break;

                case 2:
                    System.out.print("Enter Department Name: ");
                    sc.nextLine();
                    String dName = sc.nextLine();
                    Department dept = company.findDepartment(dName);

                    if (dept == null) {
                        System.out.println("Department not found!");
                        break;
                    }

                    System.out.print("1. Employee  2. Manager: ");
                    int type = sc.nextInt();

                    System.out.print("Enter ID: ");
                    int id = sc.nextInt();
                    sc.nextLine();

                    System.out.print("Enter Name: ");
                    String name = sc.nextLine();

                    System.out.print("Enter Salary: ");
                    double salary = sc.nextDouble();

                    if (type == 1) {
                        dept.addEmployee(new Employee(id, name, salary));
                    } else {
                        dept.addEmployee(new Manager(id, name, salary, dName));
                    }

                    System.out.println("Added successfully!");
                    break;

                case 3:
                    System.out.print("Enter Department Name: ");
                    sc.nextLine();
                    String dn = sc.nextLine();
                    Department d = company.findDepartment(dn);

                    if (d != null) {
                        d.displayEmployees();
                    } else {
                        System.out.println("Department not found!");
                    }
                    break;

                case 4:
                    System.out.print("Enter Department Name: ");
                    sc.nextLine();
                    String deptN = sc.nextLine();
                    Department dep = company.findDepartment(deptN);

                    if (dep != null) {
                        System.out.print("Enter Employee ID to remove: ");
                        int remId = sc.nextInt();
                        dep.removeEmployee(remId);
                    } else {
                        System.out.println("Department not found!");
                    }
                    break;

                case 5:
                    System.out.print("Enter Raise Percentage: ");
                    double percent = sc.nextDouble();
                    company.applyRaiseToAll(percent);
                    break;

                case 6:
                    company.displayDepartments();
                    break;

                case 7:
                    System.out.println("Total Employees: " + Employee.totalEmployees);
                    break;

                case 8:
                    System.out.println("Exiting...");
                    return;

                default:
                    System.out.println("Invalid choice!");
            }
        }
    }
}
