import java.util.*;

// Passenger Class
class Passenger {
    private int id;
    private String name;
    private int seatNumber;

    public Passenger(int id, String name, int seatNumber) {
        this.id = id;
        this.name = name;
        this.seatNumber = seatNumber;
    }

    public int getId() {
        return id;
    }

    public int getSeatNumber() {
        return seatNumber;
    }

    public void display() {
        System.out.println("ID: " + id + ", Name: " + name + ", Seat No: " + seatNumber);
    }
}

// Flight Class
class Flight {
    protected String flightNumber;
    protected String source;
    protected String destination;
    protected List<Passenger> passengers;

    public Flight(String flightNumber, String source, String destination) {
        this.flightNumber = flightNumber;
        this.source = source;
        this.destination = destination;
        passengers = new ArrayList<>();
    }

    // Add Passenger
    public void addPassenger(Passenger p) {
        for (Passenger existing : passengers) {
            if (existing.getSeatNumber() == p.getSeatNumber()) {
                System.out.println("Seat already booked!");
                return;
            }
        }
        passengers.add(p);
        System.out.println("Passenger added successfully!");
    }

    // Remove Passenger by ID
    public void removePassenger(int id) {
        Iterator<Passenger> it = passengers.iterator();
        while (it.hasNext()) {
            Passenger p = it.next();
            if (p.getId() == id) {
                it.remove();
                System.out.println("Passenger removed successfully!");
                return;
            }
        }
        System.out.println("Passenger not found!");
    }

    // Search Passenger by Seat Number
    public void searchPassenger(int seatNo) {
        for (Passenger p : passengers) {
            if (p.getSeatNumber() == seatNo) {
                System.out.println("Passenger Found:");
                p.display();
                return;
            }
        }
        System.out.println("Passenger not found!");
    }

    // Display All Passengers
    public void displayPassengers() {
        if (passengers.isEmpty()) {
            System.out.println("No passengers booked.");
            return;
        }

        System.out.println("\nFlight: " + flightNumber + " (" + source + " → " + destination + ")");
        for (Passenger p : passengers) {
            p.display();
        }
    }
}

// BusinessFlight Class (Inheritance)
class BusinessFlight extends Flight {
    private boolean bagAccess;

    public BusinessFlight(String flightNumber, String source, String destination, boolean bagAccess) {
        super(flightNumber, source, destination);
