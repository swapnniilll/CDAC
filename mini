    }

    @Override
    public void displayPassengers() {
        System.out.println("\nBusiness Flight: " + flightNumber);
        System.out.println("Route: " + source + " → " + destination);
        System.out.println("Extra Baggage Access: " + (bagAccess ? "Yes" : "No"));
        super.displayPassengers();
    }
}

